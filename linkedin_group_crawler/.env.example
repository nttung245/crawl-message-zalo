# false = hiện cửa sổ trình duyệt Playwright (khuyến nghị khi dev / cào nhóm)
HEADLESS=false
# false = không pre-launch Chromium lúc startup (giúp /health lên nhanh trên VM yếu)
PLAYWRIGHT_WARMUP_ON_STARTUP=true
# Số browser Chromium song song (comment/reaction không xếp hàng toàn cục). VM 8GB: 2–3
PLAYWRIGHT_POOL_SIZE=3
# Reaction Playwright — tăng nếu VM thấy menu mở nhưng Like/Love không dính (ms)
REACTION_MENU_HOVER_SETTLE_MS=1800
REACTION_POST_GOTO_SETTLE_MS=3500
REACTION_POST_CLICK_SETTLE_MS=1500
# Sau POST /login — mỗi worker pool mở feed với storage_state (tránh login lạnh khi react/comment)
LINKEDIN_SESSION_PRIME_URL=https://www.linkedin.com/feed/
LINKEDIN_SESSION_PRIME_TIMEOUT_MS=120000
STATE_PATH=storage/linkedin_state.json
DEFAULT_SCROLL_TIMES=8
DEFAULT_SCROLL_DELAY_MS=2000
DEFAULT_SCROLL_DELAY_MIN_MS=1000
DEFAULT_SCROLL_DELAY_MAX_MS=2000
DEFAULT_MAX_ITEMS=50
API_KEY=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Webhook URL workflow n8n (gửi email / xử lý thông tin đăng nhập)
N8N_WEBHOOK_URL=
# Timeout (giây) khi POST tới webhook
N8N_WEBHOOK_TIMEOUT_SEC=30
# Sau POST /linkedin/post/react — POST JSON tới URL này (ưu tiên). Fallback nếu trống: N8N_WEBHOOK_POST_REACTION
N8N_WEBHOOK_REACTION=
# (Tuỳ chọn / cũ) Chỉ dùng khi N8N_WEBHOOK_REACTION chưa set
N8N_WEBHOOK_POST_REACTION=
# Sau POST /linkedin/post/comment — webhook merge full sheet_row + app_comments (ưu tiên). Fallback: N8N_WEBHOOK_POST_COMMENT
N8N_WEBHOOK_COMMENT=
N8N_WEBHOOK_POST_COMMENT=
# Webhook n8n thứ hai: workflow trả về link Google Sheet (key đúng theo yêu cầu; có alias N8N_WEBHOOK_GET_LINK)
N8n_WEBHOOK_GET_LINK=
# Webhook chỉ POST JSON chuyển tiếp (từng endpoint API map 1-1)
N8N_WEBHOOK_GET_POST_CRAWLED=
N8N_WEBHOOK_GET_URL_GROUP_CRAWLED=
N8n_WEBHOOK_GET_RESULT_CRAWL_BY_ID=
# Quản lý nhóm (POST JSON tới n8n; email từ cookie email_crawl hoặc body.email)
N8N_WEBHOOK_GET_GROUP=
N8N_WEBHOOK_ADD_GROUP=
N8N_WEBHOOK_REMOVE_GROUP=
N8N_WEBHOOK_UPDATE_GROUP=
# Webhook POST /groups/add-list-group (batch đã cào). Ưu tiên key mới; có thể fallback N8N_WEBHOOK_BULK_IMPORT_GROUPS
N8N_WEBHOOK_ADD_LIST_GROUP=
# Timeout (giây) chờ HTTP response của webhook trên (mặc định 300 = 5 phút; n8n phải trả response khi workflow xong)
N8N_WEBHOOK_ADD_LIST_GROUP_TIMEOUT_SEC=300
# (Tùy chọn, cũ) Nếu chưa set N8N_WEBHOOK_ADD_LIST_GROUP thì vẫn đọc được URL từ biến này
N8N_WEBHOOK_BULK_IMPORT_GROUPS=
# (Tùy chọn, cũ) Timeout nếu chưa set N8N_WEBHOOK_ADD_LIST_GROUP_TIMEOUT_SEC
N8N_WEBHOOK_BULK_IMPORT_GROUPS_TIMEOUT_SEC=
HOST=0.0.0.0
PORT=8000

# false = hiện cửa sổ trình duyệt Playwright (khuyến nghị khi dev / cào nhóm)
HEADLESS=false
# false = không pre-launch Chromium lúc startup (giúp /health lên nhanh trên VM yếu)
PLAYWRIGHT_WARMUP_ON_STARTUP=true
# 1 = một Chromium, xếp hàng tuần tự (khuyến nghị ổn định). Chỉ tăng khi cần tốc độ.
PLAYWRIGHT_POOL_SIZE=1
# false = chỉ POST /login ghi file session; react/comment không ghi đè (an toàn).
PLAYWRIGHT_PERSIST_SESSION_ON_USE=false
# Tự login/prime trước react/comment (khuyến nghị true)
LINKEDIN_AUTO_LOGIN_BEFORE_ENGAGEMENT=true
# Password map JSON cho auto-login: {"user@gmail.com":"secret"}
# LINKEDIN_ENGAGEMENT_PASSWORDS_JSON=
# LINKEDIN_DEFAULT_ENGAGEMENT_PASSWORD=
# Reaction Playwright — tăng nếu VM thấy menu mở nhưng Like/Love không dính (ms)
REACTION_MENU_HOVER_SETTLE_MS=1800
REACTION_POST_GOTO_SETTLE_MS=3500
REACTION_POST_CLICK_SETTLE_MS=1500
# Sau POST /login — mỗi worker pool mở feed với storage_state (tránh login lạnh khi react/comment)
LINKEDIN_SESSION_PRIME_URL=https://www.linkedin.com/feed/
LINKEDIN_SESSION_PRIME_TIMEOUT_MS=120000
STATE_PATH=storage/linkedin_state.json
DEFAULT_SCROLL_TIMES=8
DEFAULT_SCROLL_DELAY_MS=2000
DEFAULT_SCROLL_DELAY_MIN_MS=1000
DEFAULT_SCROLL_DELAY_MAX_MS=2000
DEFAULT_MAX_ITEMS=50
API_KEY=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Webhook URL workflow n8n (gửi email / xử lý thông tin đăng nhập)
N8N_WEBHOOK_URL=
# Timeout (giây) khi POST tới webhook
N8N_WEBHOOK_TIMEOUT_SEC=30
# SECURITY: API token for n8n webhook authentication (preferred over passwords)
# Use this instead of plaintext passwords in payloads. If set, takes precedence over password-based auth.
N8N_API_TOKEN=

# LinkedIn may use Redis in other flows. Zalo ignores REDIS_URL unless
# ZALO_SESSION_STORE=redis is explicitly set, because Zalo sessions contain
# live Playwright objects. Keep Zalo on one API worker.
REDIS_URL=
# Sau POST /linkedin/post/react — POST JSON tới URL này (ưu tiên). Fallback nếu trống: N8N_WEBHOOK_POST_REACTION
N8N_WEBHOOK_REACTION=
# (Tuỳ chọn / cũ) Chỉ dùng khi N8N_WEBHOOK_REACTION chưa set
N8N_WEBHOOK_POST_REACTION=
# Sau POST /linkedin/post/comment — webhook merge full sheet_row + app_comments (ưu tiên). Fallback: N8N_WEBHOOK_POST_COMMENT
N8N_WEBHOOK_COMMENT=
N8N_WEBHOOK_POST_COMMENT=
# Webhook n8n thứ hai: workflow trả về link Google Sheet (key đúng theo yêu cầu; có alias N8N_WEBHOOK_GET_LINK)
N8n_WEBHOOK_GET_LINK=
# Webhook chỉ POST JSON chuyển tiếp (từng endpoint API map 1-1)
N8N_WEBHOOK_GET_POST_CRAWLED=
N8N_WEBHOOK_GET_URL_GROUP_CRAWLED=
N8n_WEBHOOK_GET_RESULT_CRAWL_BY_ID=
# Quản lý nhóm (POST JSON tới n8n; email từ cookie email_crawl hoặc body.email)
N8N_WEBHOOK_GET_GROUP=
N8N_WEBHOOK_ADD_GROUP=
N8N_WEBHOOK_REMOVE_GROUP=
N8N_WEBHOOK_UPDATE_GROUP=
# Webhook POST /groups/add-list-group (batch đã cào). Ưu tiên key mới; có thể fallback N8N_WEBHOOK_BULK_IMPORT_GROUPS
N8N_WEBHOOK_ADD_LIST_GROUP=
# Timeout (giây) chờ HTTP response của webhook trên (mặc định 300 = 5 phút; n8n phải trả response khi workflow xong)
N8N_WEBHOOK_ADD_LIST_GROUP_TIMEOUT_SEC=300
# (Tùy chọn, cũ) Nếu chưa set N8N_WEBHOOK_ADD_LIST_GROUP thì vẫn đọc được URL từ biến này
N8N_WEBHOOK_BULK_IMPORT_GROUPS=
# (Tùy chọn, cũ) Timeout nếu chưa set N8N_WEBHOOK_ADD_LIST_GROUP_TIMEOUT_SEC
N8N_WEBHOOK_BULK_IMPORT_GROUPS_TIMEOUT_SEC=
HOST=0.0.0.0
PORT=8000

# REQUIRED: Path to Google service account JSON file for Google Sheets API
# Example: credentials/service_account.json or /absolute/path/to/service_account.json
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service_account.json

# REQUIRED: Google Spreadsheet ID for data export
# Example: 1rfep85y5_97gnm2uIarsc6yVQIkZJYK4ALuPgzM939I
GOOGLE_SPREADSHEET_ID=

# Zalo service config
ZALO_GOOGLE_CREDENTIALS_PATH=credentials/service_account.json
ZALO_DEFAULT_SHEET_ID=10Avy_3s9VCuqb5S2uFHm0F49FSWVJz6CNDeOwupuoUY
ZALO_CORS_ORIGINS=http://localhost:3000
ZALO_SESSION_TTL_HOURS=8
ZALO_DEBUG_ARTIFACTS_DIR=artifacts/debug
ZALO_BROWSER_HEADLESS=false
ZALO_BROWSER_STEALTH=true
ZALO_BROWSER_PERSISTENT_PROFILE=true
ZALO_BROWSER_USER_DATA_DIR=storage/chromium-profile
ZALO_BROWSER_KILL_STALE_PROCESSES=true
# URL man hinh remote de thao tac Zalo thu cong (noVNC auto connect)
# Ví dụ local: http://localhost:6080/vnc.html?autoconnect=true&reconnect=true&resize=scale&show_dot=true
# Ví dụ VPS:   http://<vps-ip>:6080/vnc.html?autoconnect=true&reconnect=true&resize=scale&show_dot=true
ZALO_BROWSER_REMOTE_VIEWER_URL=

# Zalo VPS deployment
# Required only when ZALO_VNC_ENABLED=true (rescue/manual screen mode).
ZALO_VNC_PASSWORD=
ZALO_VNC_ENABLED=false
ZALO_AUTO_OPEN_ON_START=false
# Keep default bind values for safer VPS deployment. Use SSH tunnel or a protected reverse proxy.
ZALO_API_BIND=127.0.0.1
ZALO_VNC_BIND=127.0.0.1
ZALO_NOVNC_BIND=127.0.0.1
ZALO_API_WORKERS=4
# Zalo Playwright sessions are live browser objects; run one API worker.
# In docker-compose.zalo-multi.yml only zalo-api is multi-worker; zalo-browser stays single-worker.
ZALO_SESSION_STORE=memory

# Zalo Supabase storage/library. Run supabase_zalo_schema.sql in Supabase SQL editor first.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=zalo-assets
ZALO_SAVE_TO_SUPABASE=true
ZALO_WRITE_GOOGLE_SHEET=false
ZALO_BROADCAST_DELAY_SECONDS=3
ZALO_ASSET_RETENTION_DAYS=7
ZALO_ASSET_CLEANUP_BATCH_SIZE=200
